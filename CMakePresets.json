{
  "version": 8,
  "cmakeMinimumRequired": { "major": 3, "minor": 28, "patch": 0 },
  "configurePresets": [
    {
      "name": "host-debug",
      "displayName": "Host debug and tests",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${hostSystemName}/host-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "GEM16GB_ENABLE_CUDA": "OFF",
        "GEM16GB_ENABLE_SANITIZERS": "OFF",
        "GEM16GB_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "host-sanitize",
      "displayName": "Host ASan and UBSan",
      "inherits": "host-debug",
      "binaryDir": "${sourceDir}/build/${hostSystemName}/host-sanitize",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": { "GEM16GB_ENABLE_SANITIZERS": "ON" }
    },
    {
      "name": "blackwell-release",
      "displayName": "16 GB Blackwell GPU release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${hostSystemName}/blackwell-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "GEM16GB_ENABLE_CUDA": "ON",
        "GEM16GB_CUDA_ARCHITECTURE": "120a",
        "GEM16GB_BUILD_TESTS": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "host-debug", "configurePreset": "host-debug" },
    {
      "name": "host-sanitize",
      "configurePreset": "host-sanitize",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" }
    },
    { "name": "blackwell-release", "configurePreset": "blackwell-release" }
  ],
  "testPresets": [
    { "name": "host-debug", "configurePreset": "host-debug", "output": { "outputOnFailure": true } },
    {
      "name": "host-sanitize",
      "configurePreset": "host-sanitize",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" },
      "output": { "outputOnFailure": true }
    },
    { "name": "blackwell-release", "configurePreset": "blackwell-release", "output": { "outputOnFailure": true } }
  ]
}
